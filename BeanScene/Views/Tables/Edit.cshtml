@model BeanScene.Models.Table

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit Table</h1>


<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="TableId" />
            <div class="form-group">
                <label asp-for="TableCode" class="control-label"></label>
                <input asp-for="TableCode" class="form-control" />
                <span asp-validation-for="TableCode" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Capacity" class="control-label"></label>
                <input asp-for="Capacity" class="form-control" />
                <span asp-validation-for="Capacity" class="text-danger"></span>
            </div>
          <div class="mb-3">
            <label asp-for="AreaId" class="form-label">
                Area
            </label>

            <select asp-for="AreaId"
                    class="form-select"
                    asp-items="@(new SelectList(ViewBag.Areas, "AreaId", "AreaName"))">
            </select>
        </div>
           
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary"> ← Back to List</a>

            </div>
        </form>
    </div>
</div>



@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
