@{
    ViewData["Title"] = "Bean Scene";
}

<!-- Hero Section -->
<div class="bg-dark text-white text-center py-5 rounded shadow-lg">

    <h1 class="display-2 fw-bold">
        ☕ Bean Scene
    </h1>

    <p class="lead mt-3">
        Premium Coffee • Delicious Food • Memorable Experiences
    </p>

    <p class="mb-4">
        Enjoy handcrafted coffee, fresh meals, and a welcoming atmosphere.
    </p>

    <a asp-controller="Home"
       asp-action="Reservation"
       class="btn btn-warning btn-lg px-5">
        📅 Book a Table
    </a>

</div>

<!-- Features -->
<div class="container mt-5">

    <div class="row g-4">

        <div class="col-md-4">
            <div class="card shadow border-0 h-100">
                <div class="card-body text-center">

                    <h2>☕</h2>

                    <h4 class="mt-3">
                        Fresh Coffee
                    </h4>

                    <p class="text-muted">
                        Enjoy our premium coffee selection
                        prepared by expert baristas.
                    </p>

                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow border-0 h-100">
                <div class="card-body text-center">

                    <h2>🍽</h2>

                    <h4 class="mt-3">
                        Delicious Meals
                    </h4>

                    <p class="text-muted">
                        Discover breakfast, lunch and dinner
                        made from fresh ingredients.
                    </p>

                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow border-0 h-100">
                <div class="card-body text-center">

                    <h2>📅</h2>

                    <h4 class="mt-3">
                        Online Reservations
                    </h4>

                    <p class="text-muted">
                        Reserve your table anytime using our
                        easy online booking system.
                    </p>

                </div>
            </div>
        </div>

    </div>

</div>

<!-- About Section -->
<div class="container mt-5">

    <div class="card shadow border-0">

        <div class="card-body text-center p-5">

            <h2>
                Welcome to Bean Scene
            </h2>

            <p class="lead text-muted">
                A place where great coffee meets great company.
            </p>

            <p>
                Whether you're looking for your morning coffee,
                a business meeting spot, or a relaxing dinner,
                Bean Scene offers an unforgettable experience.
            </p>

        </div>

    </div>

</div>

<!-- Opening Hours -->
<div class="container mt-5 mb-5">

    <div class="row">

        <div class="col-md-6 mx-auto">

            <div class="card bg-dark text-white shadow">

                <div class="card-body text-center">

                    <h3>🕒 Opening Hours</h3>

                    <hr />

                    <p class="mb-1">
                        Monday - Friday
                    </p>

                    <strong>
                        8:00 AM - 10:00 PM
                    </strong>

                    <br /><br />

                    <p class="mb-1">
                        Saturday - Sunday
                    </p>

                    <strong>
                        8:00 AM - 11:00 PM
                    </strong>

                </div>

            </div>

        </div>

    </div>
   

</div>