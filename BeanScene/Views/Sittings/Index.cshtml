@model IEnumerable<BeanScene.Models.Sitting>

@{
    ViewData["Title"] = "Index";
}

<div class="d-flex justify-content-between align-items-center mb-4">

<h1>Sitting Managmen</h1>

<p>
    <a asp-action="Create" class="btn btn-success">Create New Sitting</a>
</p>
</div>
<table class="table">
    <thead class="table-dark">
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.SittingType)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.StartTime)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EndTime)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Capacity)
            </th>
           
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.SittingType)
            </td>
            <td>
                @Html.DisplayFor(model => item.StartTime)
            </td>
            <td>
                @Html.DisplayFor(model => item.EndTime)
            </td>
            <td>
                @Html.DisplayFor(model => item.Capacity)
            </td>
          
            <td>
                    <a asp-action="Edit" asp-route-id="@item.SittingId" class="btn btn-warning btn-sm">
                        <i class="bi bi-pencil-square"></i></a> |
                    <a asp-action="Details" asp-route-id="@item.SittingId" class="btn btn-info btn-sm">
                        <i class="bi bi-eye"></i></a> |
                    <a asp-action="Delete" asp-route-id="@item.SittingId"
                       class="btn btn-danger btn-sm"><i class="bi bi-trash"></i></a>
            </td>
        </tr>
}
    </tbody>
</table>
