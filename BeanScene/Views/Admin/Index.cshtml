@{
    ViewData["Title"] = "Dashboard";
}

<h1 class="mb-4">Management Dashboard</h1>

@if (User.IsInRole("Manager"))
{
    <div class="row">
        <div class="col-md-3 mb-3">
            <a asp-controller="Users"
               asp-action="Index"
               class="btn btn-danger w-100 p-4">
                Users
            </a>
        </div>
    </div>
}

<div class="row">

    <div class="col-md-3 mb-3">
        <a asp-controller="Reservations"
           asp-action="Index"
           class="btn btn-primary w-100 p-4">
            Reservations
        </a>
    </div>

    <div class="col-md-3 mb-3">
        <a asp-controller="Sittings"
           asp-action="Index"
           class="btn btn-success w-100 p-4">
            Sittings
        </a>
    </div>

    <div class="col-md-3 mb-3">
        <a asp-controller="Tables"
           asp-action="Index"
           class="btn btn-warning w-100 p-4">
            Tables
        </a>
    </div>

    <div class="col-md-3 mb-3">
        <a asp-controller="Areas"
           asp-action="Index"
           class="btn btn-info w-100 p-4">
            Areas
        </a>
    </div>

</div>