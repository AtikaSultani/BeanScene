@model BeanScene.Data.ApplicationUser

@{
    ViewData["Title"] = "Edit User";
}

<div class="container mt-4">

    
    <div class="card shadow">

        <div class="card-header bg-dark text-white">
            <h3>Edit User</h3>
        </div>

        <div class="card-body">

            <form asp-action="Edit"
                  enctype="multipart/form-data">

                <input asp-for="Id" type="hidden" />

                <div class="mb-3">
                    <label>Email</label>
                    <input asp-for="Email"
                           class="form-control" />
                </div>

                <div class="mb-3">
                    <label>Phone Number</label>
                    <input asp-for="PhoneNumber"
                           class="form-control" />
                </div>

                <div class="mb-3">

                    <label>Profile Photo</label>

                    <input type="file"
                           name="photo"
                           class="form-control" />

                </div>

                <button type="submit"
                        class="btn btn-primary">
                    Save Changes
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    Cancel
                </a>

            </form>

        </div>

    </div>
    

</div>
